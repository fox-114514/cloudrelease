{
  "name": "studyshot-relay-linux",
  "version": "0.5.0",
  "description": "StudyShot Relay Linux CLI client for testing auto upload/receive",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "studyshot-relay": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/web && cp src/web/index.html dist/web/index.html && cp assets/icon.svg dist/web/icon.svg",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "fastify": "^5.8.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
