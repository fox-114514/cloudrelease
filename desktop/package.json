{
  "name": "studyshot-relay-desktop",
  "version": "0.1.0",
  "description": "StudyShot Relay desktop receiver",
  "main": "dist/main.js",
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc && node scripts/copy-renderer.mjs",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "package:dir": "npm run build && electron-builder --dir",
    "package:linux": "npm run build && electron-builder --linux AppImage deb",
    "package:win": "npm run build && electron-builder --win nsis portable"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.studyshot.relay.desktop",
    "productName": "StudyShot Relay",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
