# Copy this file to .env.production on the server and replace every change-me value.

# Public URL used by clients.
DEPLOY_MODE=https
PUBLIC_BASE_URL=https://studyshot.example.com
STUDYSHOT_DOMAIN=studyshot.example.com
ACME_EMAIL=admin@example.com

# For IP-only HTTP test deployments, use:
# DEPLOY_MODE=ip-http
# PUBLIC_BASE_URL=http://1.2.3.4:3000
# PUBLIC_IP=1.2.3.4
# HTTP_PORT=3000

# Backend listen address inside the container.
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# PostgreSQL container bootstrap.
POSTGRES_USER=studyshot
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=studyshot

# Backend database URL. Host must be "postgres" when using docker-compose.prod.yml.
DATABASE_URL=postgresql://studyshot:change-me-postgres-password@postgres:5432/studyshot

# Security.
JWT_SECRET=change-me-to-at-least-32-random-bytes

# Initial owner. Used only if the owner login does not already exist.
INITIAL_OWNER_LOGIN=owner
INITIAL_OWNER_PASSWORD=change-me-owner-password

# Storage and limits.
STORAGE_DIR=/var/lib/studyshot/storage
MAX_IMAGE_SIZE_MB=30
DEFAULT_RETENTION_DAYS=30

# Optional. Leave empty unless a browser-based admin UI needs CORS.
CORS_ALLOWED_ORIGINS=

# Self-hosted update distribution. Increment Android VERSION_CODE for every APK.
# Put packages under backend/releases/<version>/ on the server. docker-compose mounts
# backend/releases/ to /var/lib/studyshot/releases/ inside the backend container.
ANDROID_UPDATE_APK_PATH=/var/lib/studyshot/releases/0.5.1/StudyShot-Relay-Android-0.5.1.apk
ANDROID_UPDATE_VERSION_CODE=9
ANDROID_UPDATE_VERSION_NAME=0.5.1
ANDROID_UPDATE_RELEASE_NOTES=Android 0.5.1：修复登录提示、补充帮助页并加入自托管更新
WINDOWS_UPDATE_PACKAGE_PATH=/var/lib/studyshot/releases/0.5.1/StudyShot-Relay-Windows-0.5.1-portable.exe
WINDOWS_UPDATE_VERSION_NAME=0.5.1
WINDOWS_UPDATE_RELEASE_NOTES=Windows 0.5.1：新增自托管更新并精简包体
LINUX_DESKTOP_UPDATE_PACKAGE_PATH=/var/lib/studyshot/releases/0.5.2/StudyShot-Relay-Desktop-Linux-0.5.2_amd64.deb
LINUX_DESKTOP_UPDATE_VERSION_NAME=0.5.2
LINUX_DESKTOP_UPDATE_RELEASE_NOTES=Linux 桌面端 0.5.2：修复 WebSocket 重连弹错和 HTTPS 下旧 HTTP 警告残留
LINUX_CLI_UPDATE_PACKAGE_PATH=/var/lib/studyshot/releases/0.5.1/StudyShot-Relay-Linux-Client-0.5.1_amd64.deb
LINUX_CLI_UPDATE_VERSION_NAME=0.5.1
LINUX_CLI_UPDATE_RELEASE_NOTES=Linux CLI/Web 0.5.1：新增 update 命令和 Web 更新入口
