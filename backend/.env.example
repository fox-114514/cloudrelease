# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
PUBLIC_BASE_URL=https://studyshot.example.com

# Database (PostgreSQL required)
DATABASE_URL=postgresql://studyshot:studyshot@localhost:5432/studyshot

# Security
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes

# Initial owner (created on first startup if not exists)
# REQUIRED: must be at least 8 characters. There is no default.
INITIAL_OWNER_LOGIN=owner
INITIAL_OWNER_PASSWORD=

# Storage
STORAGE_DIR=/var/lib/studyshot/storage

# Limits
MAX_IMAGE_SIZE_MB=30
DEFAULT_RETENTION_DAYS=30

# CORS (optional, only needed for web admin UI)
CORS_ALLOWED_ORIGINS=
