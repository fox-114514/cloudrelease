generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid()) @map("id")
  ownerUserId     String    @map("owner_user_id")
  role            UserRole  @map("role")
  displayName     String?   @map("display_name")
  emailOrLogin    String?   @unique @map("email_or_login")
  passwordHash    String?   @map("password_hash")
  createdAt       DateTime  @default(now()) @map("created_at")
  disabledAt      DateTime? @map("disabled_at")

  devices              Device[]
  auditLogs            AuditLog[]
  createdBindCodes     BindCode[] @relation("CreatedByUser")
  targetOfBindCodes    BindCode[] @relation("TargetUser")
  uploadedImages       Image[]    @relation("UploadUser")
  groupMembers         GroupMember[]

  @@index([ownerUserId])
  @@index([emailOrLogin])
  @@map("users")
}

enum UserRole {
  owner
  child

  @@map("user_role")
}

model Group {
  id          String   @id @default(uuid()) @map("id")
  ownerUserId String   @map("owner_user_id")
  name        String   @map("name")
  createdAt   DateTime @default(now()) @map("created_at")

  members GroupMember[]

  @@index([ownerUserId])
  @@map("groups")
}

model GroupMember {
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

model Device {
  id               String     @id @default(uuid()) @map("id")
  ownerUserId      String     @map("owner_user_id")
  userId           String     @map("user_id")
  name             String     @map("name")
  platform         Platform   @map("platform")
  appVersion       String     @map("app_version")
  osVersion        String     @map("os_version")
  deviceTokenHash  String     @unique @map("device_token_hash")
  publicKey        String?    @map("public_key")
  lastSeenAt       DateTime?  @map("last_seen_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  revokedAt        DateTime?  @map("revoked_at")
  deletedAt        DateTime?  @map("deleted_at")

  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions          DevicePermission?
  receiveRulesAsTarget ReceiveSourceRule[] @relation("TargetDevice")
  receiveRulesAsSource ReceiveSourceRule[] @relation("SourceDevice")
  uploadedImages       Image[]             @relation("UploadDevice")
  deliveries           Delivery[]          @relation("TargetDevice")
  usedBindCodes        BindCode[]          @relation("UsedByDevice")
  auditLogs            AuditLog[]

  @@index([ownerUserId])
  @@index([ownerUserId, deletedAt])
  @@index([userId])
  @@map("devices")
}

enum Platform {
  android
  windows
  linux

  @@map("platform")
}

model DevicePermission {
  deviceId           String            @id @map("device_id")
  canAutoUpload      Boolean           @default(false) @map("can_auto_upload")
  canManualUpload    Boolean           @default(false) @map("can_manual_upload")
  canAutoReceive     Boolean           @default(false) @map("can_auto_receive")
  canManualDownload  Boolean           @default(false) @map("can_manual_download")
  canManageSpace     Boolean           @default(false) @map("can_manage_space")
  canCreateInvite    Boolean           @default(false) @map("can_create_invite")
  autoUploadScope    AutoUploadScope   @default(screenshot_only) @map("auto_upload_scope")
  autoReceiveScope   AutoReceiveScope  @default(disabled) @map("auto_receive_scope")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("device_permissions")
}

enum AutoUploadScope {
  screenshot_only
  selected_album
  manual_share_only
  all_images

  @@map("auto_upload_scope")
}

enum AutoReceiveScope {
  disabled
  all_authorized_sources
  same_user_only
  selected_devices

  @@map("auto_receive_scope")
}

model ReceiveSourceRule {
  targetDeviceId String   @map("target_device_id")
  sourceDeviceId String   @map("source_device_id")
  enabled        Boolean  @default(true) @map("enabled")
  createdAt      DateTime @default(now()) @map("created_at")

  targetDevice Device @relation("TargetDevice", fields: [targetDeviceId], references: [id], onDelete: Cascade)
  sourceDevice Device @relation("SourceDevice", fields: [sourceDeviceId], references: [id], onDelete: Cascade)

  @@id([targetDeviceId, sourceDeviceId])
  @@index([sourceDeviceId])
  @@map("receive_source_rules")
}

model Image {
  id                   String          @id @default(uuid()) @map("id")
  ownerUserId          String          @map("owner_user_id")
  uploadUserId         String          @map("upload_user_id")
  uploadDeviceId       String          @map("upload_device_id")
  originImageId        String?         @map("origin_image_id")
  sha256               String          @map("sha256")
  mimeType             String          @map("mime_type")
  fileSize             Int             @map("file_size")
  width                Int?            @map("width")
  height               Int?            @map("height")
  storageKey           String          @unique @map("storage_key")
  sourceKind           ImageSourceKind @default(unknown) @map("source_kind")
  sourceDisplayName    String?         @map("source_display_name")
  sourceMediaIdHash    String?         @map("source_media_id_hash")
  createdAt            DateTime        @default(now()) @map("created_at")
  expiresAt            DateTime        @map("expires_at")
  deletedAt            DateTime?       @map("deleted_at")

  uploadUser   User       @relation("UploadUser", fields: [uploadUserId], references: [id], onDelete: Cascade)
  uploadDevice Device     @relation("UploadDevice", fields: [uploadDeviceId], references: [id], onDelete: Cascade)
  deliveries   Delivery[]

  @@index([ownerUserId])
  @@index([uploadDeviceId])
  @@index([sha256])
  @@index([expiresAt])
  @@map("images")
}

enum ImageSourceKind {
  screenshot
  manual_share
  selected_album
  unknown

  @@map("image_source_kind")
}

model Delivery {
  id             String          @id @default(uuid()) @map("id")
  imageId        String          @map("image_id")
  targetDeviceId String          @map("target_device_id")
  status         DeliveryStatus  @default(pending) @map("status")
  failureReason  String?         @map("failure_reason")
  notifiedAt     DateTime?       @map("notified_at")
  downloadedAt   DateTime?       @map("downloaded_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  image        Image   @relation(fields: [imageId], references: [id], onDelete: Cascade)
  targetDevice Device  @relation("TargetDevice", fields: [targetDeviceId], references: [id], onDelete: Cascade)

  @@index([targetDeviceId, status])
  @@index([imageId])
  @@map("deliveries")
}

enum DeliveryStatus {
  pending
  notified
  downloaded
  failed
  skipped
  expired

  @@map("delivery_status")
}

model BindCode {
  id               String      @id @default(uuid()) @map("id")
  ownerUserId      String      @map("owner_user_id")
  createdByUserId  String      @map("created_by_user_id")
  targetUserId     String      @map("target_user_id")
  codeHash         String      @unique @map("code_hash")
  purpose          BindPurpose @map("purpose")
  targetRole       UserRole?   @map("target_role")
  expiresAt        DateTime    @map("expires_at")
  usedAt           DateTime?   @map("used_at")
  usedByDeviceId   String?     @map("used_by_device_id")
  createdAt        DateTime    @default(now()) @map("created_at")

  createdByUser  User     @relation("CreatedByUser", fields: [createdByUserId], references: [id], onDelete: Cascade)
  targetUser     User     @relation("TargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  usedByDevice   Device?  @relation("UsedByDevice", fields: [usedByDeviceId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([expiresAt])
  @@map("bind_codes")
}

enum BindPurpose {
  bind_device
  invite_child_user

  @@map("bind_purpose")
}

model AuditLog {
  id            String    @id @default(uuid()) @map("id")
  ownerUserId   String    @map("owner_user_id")
  actorUserId   String?   @map("actor_user_id")
  actorDeviceId String?   @map("actor_device_id")
  action        String    @map("action")
  targetType    String?   @map("target_type")
  targetId      String?   @map("target_id")
  metadataJson  Json?     @map("metadata_json")
  createdAt     DateTime  @default(now()) @map("created_at")

  actorUser   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorDevice Device? @relation(fields: [actorDeviceId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([createdAt])
  @@index([actorDeviceId])
  @@map("audit_logs")
}
