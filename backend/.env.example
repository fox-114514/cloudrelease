# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
PUBLIC_BASE_URL=https://studyshot.example.com

# Database (PostgreSQL required)
DATABASE_URL=postgresql://studyshot:studyshot@localhost:5432/studyshot

# Security
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes

# Initial owner (created on first startup if not exists)
# REQUIRED: must be at least 8 characters. There is no default.
INITIAL_OWNER_LOGIN=owner
INITIAL_OWNER_PASSWORD=

# Storage
STORAGE_DIR=/var/lib/studyshot/storage

# Limits
MAX_IMAGE_SIZE_MB=30
DEFAULT_RETENTION_DAYS=30

# CORS (optional, only needed for web admin UI)
CORS_ALLOWED_ORIGINS=

# Trusted reverse-proxy hops. Set to a comma-separated list when the backend
# runs behind Caddy/Nginx/a container bridge so Fastify can read the real
# client IP for rate limiting and audit (e.g. "127.0.0.1,::1,10.0.0.0/8").
# Leave empty (= trust no hop) for direct deployments.
TRUST_PROXY=

# Self-hosted client updates (optional; configure each channel independently)
ANDROID_UPDATE_APK_PATH=/var/lib/studyshot/releases/studyshot-relay.apk
ANDROID_UPDATE_VERSION_CODE=
ANDROID_UPDATE_VERSION_NAME=
ANDROID_UPDATE_RELEASE_NOTES=
WINDOWS_UPDATE_PACKAGE_PATH=/var/lib/studyshot/releases/0.5.7/StudyShot-Relay-Windows-0.5.7-portable.exe
WINDOWS_UPDATE_VERSION_NAME=
WINDOWS_UPDATE_RELEASE_NOTES=
LINUX_DESKTOP_UPDATE_PACKAGE_PATH=/var/lib/studyshot/releases/0.5.7/StudyShot-Relay-Desktop-Linux-0.5.7_amd64.deb
LINUX_DESKTOP_UPDATE_VERSION_NAME=
LINUX_DESKTOP_UPDATE_RELEASE_NOTES=
LINUX_CLI_UPDATE_PACKAGE_PATH=/var/lib/studyshot/releases/studyshot-relay-linux_0.5.1_amd64.deb
LINUX_CLI_UPDATE_VERSION_NAME=
LINUX_CLI_UPDATE_RELEASE_NOTES=
